# ── Application ──────────────────────────────────────────────
APP_ENV=development
SECRET_KEY=change-me-use-openssl-rand-hex-32-to-generate
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Database (PostgreSQL) ─────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=talent_hub
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/talent_hub

# ── Redis ─────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── LLM — Groq (free tier, only LLM provider) ────────────────
GROQ_API_KEY=gsk_your_key_here
GROQ_MODEL=llama-3.3-70b-versatile


# ── Vector Store — ChromaDB (local, free) ────────────────────
CHROMA_HOST=localhost
CHROMA_PORT=8001
CHROMA_PERSIST_DIR=./chroma_db

# ── File Storage (local, free) ───────────────────────────────
UPLOAD_DIR=./data/uploads

# ── LangSmith Tracing (optional, free tier) ──────────────────
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=ai-talent-hub

# ── CORS ─────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ── SMTP (optional, for Phase 6 notifications) ───────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SENDER=
SMTP_PASSWORD=